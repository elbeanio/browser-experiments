{
  "name": "browser-experiments",
  "version": "0.0.0",
  "private": true,
  "description": "Browser visualization experiments with WebGPU",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @browser-experiments/showcase dev",
    "build": "pnpm --filter @browser-experiments/showcase build",
    "preview": "pnpm --filter @browser-experiments/showcase preview",
    "typecheck": "pnpm --filter @browser-experiments/showcase typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.7",
    "vitest": "^3.0.7"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
